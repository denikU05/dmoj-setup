# Your server IP or domain
# Use "localhost" for local access only
# Use your local IP (e.g. 192.168.1.100) for access from other machines on the network
# Use your domain name (e.g. mydomain.com) for public access
HOST=localhost

# Database password for the DMOJ MySQL user
DB_PASS=dmojpass

# Judge name — must match the name you set in the admin panel at /admin
JUDGE_NAME=judge1

# Judge authentication key — must match the key you set in the admin panel at /admin
JUDGE_KEY=judgekeypass

# Judge tier — determines which programming languages are supported
# tier1 — Python 2/3, C/C++ (GCC), Java 8, Pascal (lightest, recommended for most use cases)
# tier2 — everything in tier1 + more languages
# tier3 — all languages supported on dmoj.ca (heaviest, requires more disk space and build time)
JUDGE_TIER=1

# The number of concurrent threads for judging submissions.
JUDGE_CONCURRENCY=1

# Credentials for the superuser account
ADMIN_USER=admin
ADMIN_PASS=super_secret_password
ADMIN_EMAIL=admin@localhost